{
  "name": "lisca-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"vite\" \"wait-on file:electron-dist/main.cjs tcp:5173 && electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "tsc && vite build",
    "build": "bun run build:electron && bun run build:renderer",
    "pack": "bunx electron-builder",
    "test": "bun test",
    "postinstall": "electron-rebuild -f"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "sql.js": "^1.14.0",
    "tailwind-merge": "^3.4.0",
    "utif2": "^4.1.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^34.5.8",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.5",
    "tw-animate-css": "^1.4.0"
  },
  "build": {
    "artifactName": "lisca-desktop-windows-x86_64.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ]
  }
}
