{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lisca-desktop",
  "version": "0.1.0",
  "identifier": "com.lisca.desktop",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build:renderer",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  },
  "app": {
    "windows": [
      {
        "title": "Lisca Desktop",
        "width": 1400,
        "height": 900
      }
    ]
  }
}
